SECRET_KEY=change-this-to-a-random-64-char-string
GEMINI_API_KEY=get-free-key-at-aistudio.google.com
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Database ──────────────────────────────────────────────────────────────────
# Option A — Neon (recommended, free): https://neon.tech
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Option B — Supabase (free): https://supabase.com
# DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# Option C — Aiven (free): https://aiven.io
# DATABASE_URL=postgresql://user:password@pg-xxxx.aivencloud.com:12345/defaultdb?sslmode=require

# Option D — SQLite (local dev only, NOT for Render/Vercel)
DATABASE_URL=sqlite:///./finwell.db
